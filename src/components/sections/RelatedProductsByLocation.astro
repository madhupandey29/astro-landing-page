---
export interface Props {
  currentSlug?: string; // when on /[slug]
  cityCode?: string;    // when on /
  title?: string;
  subtitle?: string;
}

const {
  currentSlug,
  cityCode,
  title = 'Explore Our Fabric Catalog',
  subtitle
} = Astro.props as Props;

/* ================= Helpers ================= */

const norm = (s: any) => String(s ?? '').trim().toLowerCase();

const toId = (v: any) =>
  typeof v === 'string'
    ? v.trim()
    : v && v._id
    ? String(v._id).trim()
    : '';

const BASE = (import.meta.env.BASE_URL ?? '/').toString().replace(/\/+$/, '');

function cityTokenInSlug(slug: string, city: string) {
  const c = norm(city).replace(/\s+/g, '-');
  const re = new RegExp(`(^|-)${c}(-|$)`, 'i');
  return re.test(String(slug || '').toLowerCase());
}

async function fetchJson(url: string) {
  try {
    const res = await fetch(url, { headers: { Accept: 'application/json' } });
    if (!res.ok) return null;
    return await res.json();
  } catch {
    return null;
  }
}

/* ================= API roots ================= */

const API_ROOT = (import.meta.env.PUBLIC_API_BASE_URL ?? 'https://test.amrita-fashions.com/landing')
  .toString()
  .replace(/\/+$/, '');

const SEO_URL     = `${API_ROOT}/seo`;
const PRODUCT_URL = `${API_ROOT}/product`;
const LOC_URL     = `${API_ROOT}/locations`;

const [seoJson, prodJson, locJson] = await Promise.all([
  fetchJson(SEO_URL),
  fetchJson(PRODUCT_URL),
  fetchJson(LOC_URL)
]);

const seos: any[] = Array.isArray(seoJson?.data)
  ? seoJson.data
  : Array.isArray(seoJson)
  ? seoJson
  : [];

const allProducts: any[] =
  Array.isArray(prodJson?.data?.products)
    ? prodJson.data.products
    : Array.isArray(prodJson?.data)
    ? prodJson.data
    : Array.isArray(prodJson)
    ? prodJson
    : [];

const rawLocs =
  locJson?.data?.locations ??
  locJson?.data ??
  locJson?.locations ??
  [];

const locs: any[] = Array.isArray(rawLocs) ? rawLocs : [];

/* ================= Target location / hero ================= */

let targetLocId = '';
let targetCode  = '';
let heroProductId = '';

if (currentSlug) {
  const row = seos.find((r) => norm(r?.slug) === norm(currentSlug));

  if (row) {
    // use location _id as primary anchor
    targetLocId   = toId(row.location);
    targetCode    = norm(row.locationCode);
    heroProductId = toId(row.product);
  } else {
    // fallback: try to infer from slug suffix (e.g. ...-ahmedabad)
    const m = String(currentSlug).toLowerCase().match(/-([a-z0-9-]+)$/i);
    if (m?.[1]) targetCode = m[1];
  }
} else if (cityCode) {
  const loc = locs.find(
    (l) =>
      norm(l?.slug) === norm(cityCode) ||
      norm(l?.name) === norm(cityCode) ||
      norm(l?.code) === norm(cityCode)
  );

  if (loc) {
    targetLocId = toId(loc._id || loc.id);
    targetCode  = norm(loc.code || loc.slug || loc.name || cityCode);
  } else {
    targetCode = norm(cityCode);
  }
}

/* ================= Location predicate ================= */
/**
 * "same location" = same location _id.
 * Only if we DON'T have a reliable targetLocId do we fall back to:
 * - matching locationCode
 * - or slug containing city token.
 */
function sameLocation(s: any): boolean {
  const locId = toId(s?.location);
  const code  = norm(s?.locationCode);

  // 1) strict: both have location id
  if (targetLocId && locId) {
    return targetLocId === locId;
  }

  // 2) fallback: only if we don't know targetLocId
  if (!targetLocId && targetCode && code) {
    return targetCode === code;
  }

  // 3) last fallback: only if no targetLocId and we have a hint
  const hint = !targetLocId ? (targetCode || cityCode || '') : '';
  if (hint) {
    return cityTokenInSlug(String(s?.slug || ''), hint);
  }

  return false;
}

/* ================= Collect related product IDs ================= */

const slugByProduct = new Map<string, string>();
const orderedIds: string[] = [];

// Build mapping + ordered id list for same-location SEO rows
for (const s of seos) {
  const pid   = toId(s.product);
  const sSlug = String(s?.slug ?? '').trim();
  if (!pid || !sSlug) continue;

  if (sameLocation(s)) {
    if (!orderedIds.includes(pid)) {
      orderedIds.push(pid);
    }
    slugByProduct.set(pid, sSlug);
  } else if (!slugByProduct.has(pid)) {
    // keep slug map for non-related items (for /api usage / navigation)
    slugByProduct.set(pid, sSlug);
  }
}

// Remove current hero product on slug page
const filteredIds = orderedIds.filter((id) => id !== heroProductId);

// Materialize from /product API
const materialized = filteredIds
  .map((id) => allProducts.find((p) => String(p?._id) === id))
  .filter(Boolean);

/* ================= UI limits & mapping ================= */

const MAX_INITIAL_VISIBLE = 3; // show only 3 in UI; rest via Load more
const totalProducts       = materialized.length;
const showLoadMore        = totalProducts > MAX_INITIAL_VISIBLE;

const cardData = (p: any) => {
  const pid  = String(p?._id ?? '').trim();
  const slug = slugByProduct.get(pid) || p?.slug || '';
  const href = slug ? `${BASE}/${encodeURIComponent(slug)}` : '#';
  const img  = p?.img || p?.image1 || p?.image2 || '/placeholder.svg?height=500&width=600';
  const name = p?.name || 'Fabric';
  const desc = (p?.productdescription || '').toString();
  return { pid, href, img, name, desc };
};
---

<section class="fabric-catalog" id="products">
  <div class="catalog-container">
    <div class="catalog-header">
      <h2 class="catalog-title">{title}</h2>
      {subtitle && <p class="catalog-subtitle">{subtitle}</p>}
    </div>

    {materialized.length === 0 ? (
      <div class="empty-state">
        <div class="empty-icon">📦</div>
        <h3>No Products Available</h3>
        <p>No related products found for this location.</p>
      </div>
    ) : (
      <>
        <div class="products-grid" id="related-grid">
          {materialized.map((p, index) => {
            const d = cardData(p);
            const isHidden = index >= MAX_INITIAL_VISIBLE;
            return (
              <article
                class={`product-card ${isHidden ? 'hidden-card' : ''}`}
                data-id={d.pid}
                style={isHidden ? 'display: none;' : ''}
              >
                <div class="card-image">
                  <a href={d.href} class="image-link">
                    <img
                      src={d.img}
                      alt={d.name}
                      loading="lazy"
                      class="product-image"
                    />
                    <div class="image-overlay"></div>
                  </a>
                </div>

                <div class="card-content">
                  <h3 class="product-name">
                    <a href={d.href}>{d.name}</a>
                  </h3>
                  <p class="product-description">
                    {d.desc}
                  </p>
                  <div class="card-actions">
                    <a class="view-details" href={d.href}>
                      <span>View Details</span>
                      <svg
                        width="16"
                        height="16"
                        viewBox="0 0 24 24"
                        fill="none"
                        aria-hidden="true"
                      >
                        <path
                          d="M5 12h14m-7-7l7 7-7 7"
                          stroke="currentColor"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                        />
                      </svg>
                    </a>
                  </div>
                </div>
              </article>
            );
          })}
        </div>

        {showLoadMore && (
          <div class="loadmore-wrap">
            <button
              id="load-more-related"
              class="loadmore-btn"
              type="button"
            >
              Load More ({materialized.length - MAX_INITIAL_VISIBLE} more)
            </button>
          </div>
        )}
      </>
    )}
  </div>
</section>

<style>
.fabric-catalog {
  position: relative;
  padding: clamp(2.5rem, 4vw, 5rem) 0;
}
.fabric-catalog::before {
  content: "";
  position: absolute;
  inset-inline: 0;
  top: 0;
  height: 1px;
  background: linear-gradient(
    90deg,
    transparent 0%,
    #e2e8f0 50%,
    transparent 100%
  );
}
.catalog-container {
  max-width: 80rem;
  margin: 0 auto;
  padding-inline: 1.25rem;
}
.catalog-header {
  text-align: center;
  margin-bottom: clamp(1.5rem, 3vw, 3.75rem);
}
.catalog-title {
  margin: 0 0 0.75rem;
  line-height: 1.2;
  font-size: clamp(2rem, 4vw, 3rem);
  font-weight: 800;
  background: linear-gradient(135deg, #0f2235 0%, #2d3748 100%);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
}
.catalog-subtitle {
  margin: 0 auto;
  max-width: 37.5rem;
  font-size: 1.125rem;
  color: #64748b;
  line-height: 1.6;
}

/* Grid & cards */
.products-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 2rem;
  justify-content: center;
}

.product-card {
  position: relative;
  background: #ffffff;
  border-radius: 1.25rem;
  overflow: hidden;
  border: 1px solid #f1f5f9;
  box-shadow: 0 0.25rem 1.5rem rgba(0, 0, 0, 0.08);
  transition:
    transform 0.3s cubic-bezier(0.4, 0, 0.2, 1),
    box-shadow 0.3s cubic-bezier(0.4, 0, 0.2, 1),
    border-color 0.3s;
  flex: 0 0 22rem;            /* ~3 cards per row on desktop */
  max-width: 22rem;
  height: 100%;
  display: flex;
  flex-direction: column;
}
.product-card:hover {
  transform: translateY(-0.5rem);
  box-shadow: 0 1.5rem 3rem rgba(0, 0, 0, 0.12);
  border-color: #e2e8f0;
}

.card-image {
  position: relative;
  overflow: hidden;
  background: #f8fafc;
}
.image-link {
  display: block;
  position: relative;
}
.product-image {
  width: 100%;
  height: clamp(14rem, 26vw, 17.5rem);
  object-fit: cover;
  transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
}
.product-card:hover .product-image {
  transform: scale(1.05);
}
.image-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to bottom,
    transparent 0%,
    rgba(0, 0, 0, 0.02) 100%
  );
}

.card-content {
  padding: 1.5rem;
  display: flex;
  flex-direction: column;
  flex: 1 1 auto;
}

/* Title: wrapped & equal height (2 lines) */
.product-name {
  margin: 0 0 0.75rem;
  font-size: 1.25rem;
  font-weight: 700;
  color: #0f2235;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;   /* clamp long titles */
  -webkit-box-orient: vertical;
  overflow: hidden;
  min-height: 3.2em;       /* force 2-line space for equal card height */
}
.product-name a {
  color: inherit;
  text-decoration: none;
}
.product-name a:hover {
  color: #2c4c97;
}

/* Description: also clamped and equal height */
.product-description {
  margin: 0 0 1.25rem;
  color: #64748b;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 3;   /* clamp long descriptions */
  -webkit-box-orient: vertical;
  overflow: hidden;
  min-height: 4.8em;       /* ~3 lines */
}
.card-actions {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  margin-top: auto; /* push CTA to bottom for equal heights */
}

/* CTA button */
.view-details {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.75rem 1.25rem;
  border-radius: 0.75rem;
  font-weight: 700;
  font-size: 0.95rem;
  color: #ffffff;
  text-decoration: none;
  background: linear-gradient(135deg, #2c4c97 0%, #1e3a8a 100%);
  box-shadow: 0 0.125rem 0.75rem rgba(44, 76, 151, 0.3);
  transition:
    transform 0.2s,
    box-shadow 0.2s,
    background 0.2s;
}
.view-details:hover {
  transform: translateY(-0.125rem);
  box-shadow: 0 0.25rem 1.25rem rgba(44, 76, 151, 0.4);
  background: linear-gradient(135deg, #1e3a8a 0%, #1e40af 100%);
}
.view-details svg {
  transition: transform 0.2s ease;
}
.view-details:hover svg {
  transform: translateX(0.25rem);
}

/* Empty state */
.empty-state {
  text-align: center;
  padding: 5rem 1.25rem;
  background: #ffffff;
  border-radius: 1.5rem;
  border: 1px solid #f1f5f9;
  box-shadow: 0 0.25rem 1.5rem rgba(0, 0, 0, 0.06);
}
.empty-icon {
  font-size: 4rem;
  margin-bottom: 1rem;
  opacity: 0.7;
}
.empty-state h3 {
  margin: 0 0 0.75rem;
  font-size: 1.5rem;
  font-weight: 700;
  color: #0f2235;
}
.empty-state p {
  margin: 0;
  color: #64748b;
  font-size: 1.05rem;
}

/* Load more */
.loadmore-wrap {
  display: flex;
  justify-content: center;
  margin-top: 1.5rem;
}
.loadmore-btn {
  appearance: none;
  border: 0;
  cursor: pointer;
  padding: 0.875rem 1.25rem;
  border-radius: 0.75rem;
  font-weight: 700;
  font-size: 1rem;
  line-height: 1;
  color: #ffffff;
  background: linear-gradient(135deg, #2c4c97 0%, #1e3a8a 100%);
  box-shadow: 0 0.125rem 0.75rem rgba(44, 76, 151, 0.3);
  transition:
    transform 0.2s ease,
    box-shadow 0.2s ease,
    opacity 0.2s ease;
}
.loadmore-btn:hover {
  transform: translateY(-0.125rem);
  box-shadow: 0 0.25rem 1.25rem rgba(44, 76, 151, 0.4);
}
.loadmore-btn:disabled {
  opacity: 0.7;
  cursor: not-allowed;
}

/* Mobile */
@media (max-width: 48rem) {
  .catalog-container {
    padding-inline: 1rem;
  }
  .products-grid {
    justify-content: center;
  }
  .product-card {
    flex: 0 0 100%;
    max-width: 100%;
  }
  .product-image {
    height: 15rem;
  }
}
</style>

<script>
// Load More functionality
document.addEventListener('DOMContentLoaded', function() {
  const loadMoreBtn = document.getElementById('load-more-related');
  const productsGrid = document.getElementById('related-grid');
  
  if (!loadMoreBtn || !productsGrid) return;

  const hiddenCards = Array.from(productsGrid.querySelectorAll('.product-card[style*="display: none"]'));
  let currentIndex = 0;
  const cardsPerLoad = 3; // Show 3 cards at a time

  function showMoreCards() {
    // Show loading state
    loadMoreBtn.disabled = true;
    loadMoreBtn.textContent = 'Loading...';

    // Simulate a small delay for better UX
    setTimeout(() => {
      const endIndex = Math.min(currentIndex + cardsPerLoad, hiddenCards.length);
      
      for (let i = currentIndex; i < endIndex; i++) {
        const card = hiddenCards[i];
        if (card) {
          card.style.display = ''; // Remove display: none
          card.classList.remove('hidden-card');
        }
      }
      
      currentIndex = endIndex;
      
      // Update button text or hide if no more cards
      const remaining = hiddenCards.length - currentIndex;
      if (remaining <= 0) {
        loadMoreBtn.style.display = 'none';
      } else {
        loadMoreBtn.textContent = `Load More (${remaining} more)`;
        loadMoreBtn.disabled = false;
      }
    }, 300);
  }

  loadMoreBtn.addEventListener('click', showMoreCards);
});
</script>