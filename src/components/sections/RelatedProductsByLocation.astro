---
export interface Props {
  currentSlug?: string; // when on /[slug]
  cityCode?: string;    // when on /
  title?: string;
  subtitle?: string;
}
const { currentSlug, cityCode, title = 'Explore Our Fabric Catalog', subtitle } = Astro.props;

/* ===== Helpers ===== */
const norm = (s: any) => String(s ?? '').trim().toLowerCase();
const toId = (v: any) =>
  typeof v === 'string' ? v.trim() : v?._id ? String(v._id).trim() : '';
const BASE = (import.meta.env.BASE_URL ?? '/').replace(/\/+$/, '');
function cityTokenInSlug(slug: string, city: string) {
  const c = norm(city).replace(/\s+/g, '-');
  const re = new RegExp(`(^|-)${c}(-|$)`, 'i');
  return re.test(String(slug || '').toLowerCase());
}
async function fetchJson(url: string) {
  try {
    const res = await fetch(url, { headers: { Accept: 'application/json' } });
    if (!res.ok) return null;
    return await res.json();
  } catch {
    return null;
  }
}

/* ===== API roots ===== */
const API_ROOT = (import.meta.env.PUBLIC_API_BASE_URL ?? 'https://test.amrita-fashions.com/landing').replace(/\/+$/, '');
const SEO_URL = `${API_ROOT}/seo`;
const PRODUCT_URL = `${API_ROOT}/product`;
const LOC_URL = `${API_ROOT}/locations`;

const [seoJson, prodJson, locJson] = await Promise.all([
  fetchJson(SEO_URL),
  fetchJson(PRODUCT_URL),
  fetchJson(LOC_URL),
]);

const seos: any[] = Array.isArray(seoJson?.data) ? seoJson.data : [];
const allProducts: any[] =
  Array.isArray(prodJson?.data) ? prodJson.data :
  Array.isArray(prodJson?.data?.products) ? prodJson.data.products :
  Array.isArray(prodJson) ? prodJson : [];

const rawLocs = locJson?.data?.locations ?? locJson?.data ?? locJson?.locations ?? [];
const locs: any[] = Array.isArray(rawLocs) ? rawLocs : [];

/* Determine target location from slug OR city */
let targetLocId = '';
let targetCode = '';
let heroProductId = '';

if (currentSlug) {
  const row = seos.find((r) => norm(r?.slug) === norm(currentSlug));
  if (row) {
    targetLocId = toId(row.location);
    targetCode = norm(row.locationCode);
    heroProductId = toId(row.product);
  } else {
    // derive from slug token (fallback)
    const cityFromSlug = ((): string | null => {
      const m = String(currentSlug).toLowerCase().match(/-([a-z]+)$/i);
      return m?.[1] || null;
    })();
    if (cityFromSlug) targetCode = cityFromSlug;
  }
} else if (cityCode) {
  const loc = locs.find(
    (l) => norm(l?.slug) === norm(cityCode) || norm(l?.name) === norm(cityCode) || norm(l?.code) === norm(cityCode)
  );
  targetLocId = toId(loc);
  targetCode = norm(loc?.code) || norm(cityCode);
}

/* Same-location predicate */
function sameLocation(s: any) {
  const locId = toId(s?.location);
  const code = norm(s?.locationCode);

  if (targetLocId && locId) return targetLocId === locId;
  if (targetCode && code) return targetCode === code;

  // last fallback: use slug city token if we have a city hint (from cityCode or slug)
  const hint = targetCode || cityCode || '';
  return hint ? cityTokenInSlug(String(s?.slug || ''), hint) : false;
}

/* Collect product ids & slug per product (prefer same location) */
const slugByProduct = new Map<string, string>();
const productIds = new Set<string>();

for (const s of seos) {
  const pid = toId(s.product);
  const sSlug = String(s?.slug ?? '').trim();
  if (!pid || !sSlug) continue;

  if (sameLocation(s)) {
    productIds.add(pid);
    slugByProduct.set(pid, sSlug); // override with same-location
  } else if (!slugByProduct.has(pid)) {
    slugByProduct.set(pid, sSlug); // fallback slug
  }
}

const related = allProducts.filter((p) => productIds.has(String(p?._id)));
/* On slug pages, hide the hero product in the grid */
const gridProducts = heroProductId ? related.filter((p) => String(p?._id) !== heroProductId) : related;
---

<section class="fabric-catalog" id="products">
  <div class="catalog-container">
    <div class="catalog-header">
      <h2 class="catalog-title">{title}</h2>
      {subtitle && <p class="catalog-subtitle">{subtitle}</p>}
    </div>

    {gridProducts.length === 0 ? (
      <div class="empty-state">
        <div class="empty-icon">📦</div>
        <h3>No Products Available</h3>
        <p>No related products found for this location.</p>
      </div>
    ) : (
      <div class="products-grid">
        {gridProducts.map((p) => {
          const pid = String(p?._id ?? '').trim();
          const slug = slugByProduct.get(pid) || p?.slug || '';
          const href = slug ? `${BASE}/${encodeURIComponent(slug)}` : '#';
          const img = p?.img || p?.image1 || p?.image2 || '/placeholder.svg?height=500&width=600';
          const name = p?.name || 'Fabric';
          const desc = (p?.productdescription || '').toString();

          return (
            <article class="product-card" key={pid}>
              <div class="card-image">
                <a href={href} class="image-link">
                  <img src={img} alt={name} loading="lazy" class="product-image" />
                  <div class="image-overlay"></div>
                </a>
              </div>
              
              <div class="card-content">
                <h3 class="product-name">
                  <a href={href}>{name}</a>
                </h3>
                <p class="product-description">{desc}</p>
                <div class="card-actions">
                  <a class="view-details" href={href}>
                    <span>View Details</span>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                      <path d="M5 12h14m-7-7l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </a>
                </div>
              </div>
            </article>
          );
        })}
      </div>
    )}
  </div>
</section>

<style>
.fabric-catalog {
  padding: 80px 0;
  position: relative;
}

.fabric-catalog::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent 0%, #e2e8f0 50%, transparent 100%);
}

.catalog-container {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 24px;
}

.catalog-header {
  text-align: center;
  margin-bottom: 60px;
}

.catalog-title {
  font-size: clamp(2rem, 4vw, 3rem);
  font-weight: 800;
  background: linear-gradient(135deg, #0f2235 0%, #2d3748 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin: 0 0 16px;
  line-height: 1.2;
}

.catalog-subtitle {
  font-size: 1.25rem;
  color: #64748b;
  margin: 0;
  line-height: 1.6;
  max-width: 600px;
  margin-left: auto;
  margin-right: auto;
}

.empty-state {
  text-align: center;
  padding: 80px 20px;
  background: white;
  border-radius: 24px;
  box-shadow: 0 4px 24px rgba(0, 0, 0, 0.06);
  border: 1px solid #f1f5f9;
}

.empty-icon {
  font-size: 4rem;
  margin-bottom: 24px;
  opacity: 0.7;
}

.empty-state h3 {
  font-size: 1.5rem;
  font-weight: 700;
  color: #0f2235;
  margin: 0 0 12px;
}

.empty-state p {
  color: #64748b;
  margin: 0;
  font-size: 1.1rem;
}

.products-grid {
  display: grid;
  gap: 32px;
  grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
}

.product-card {
  background: white;
  border-radius: 20px;
  overflow: hidden;
  box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08);
  border: 1px solid #f1f5f9;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
}

.product-card:hover {
  transform: translateY(-8px);
  box-shadow: 0 24px 48px rgba(0, 0, 0, 0.12);
  border-color: #e2e8f0;
}

.card-image {
  position: relative;
  overflow: hidden;
  background: #f8fafc;
}

.image-link {
  display: block;
  position: relative;
  overflow: hidden;
}

.product-image {
  width: 100%;
  height: 280px;
  object-fit: contain;
  transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
}

.product-card:hover .product-image {
  transform: scale(1.05);
}

.image-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to bottom, transparent 0%, rgba(0, 0, 0, 0.02) 100%);
  transition: background 0.3s ease;
}

.card-content {
  padding: 24px;
}

.product-name {
  font-size: 1.25rem;
  font-weight: 700;
  color: #0f2235;
  margin: 0 0 12px;
  line-height: 1.4;
}

.product-name a {
  color: inherit;
  text-decoration: none;
  transition: color 0.2s ease;
}

.product-name a:hover {
  color: #2C4C97;
}

.product-description {
  color: #64748b;
  line-height: 1.6;
  margin: 0 0 20px;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.card-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.view-details {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 12px 20px;
  background: linear-gradient(135deg, #2C4C97 0%, #1e3a8a 100%);
  color: white;
  text-decoration: none;
  border-radius: 12px;
  font-weight: 600;
  font-size: 0.95rem;
  transition: all 0.3s ease;
  box-shadow: 0 2px 12px rgba(44, 76, 151, 0.3);
}

.view-details:hover {
  transform: translateY(-2px);
  box-shadow: 0 4px 20px rgba(44, 76, 151, 0.4);
  background: linear-gradient(135deg, #1e3a8a 0%, #1e40af 100%);
}

.view-details svg {
  transition: transform 0.3s ease;
}

.view-details:hover svg {
  transform: translateX(4px);
}

@media (max-width: 768px) {
  .fabric-catalog {
    padding: 60px 0;
  }
  
  .catalog-container {
    padding: 0 20px;
  }
  
  .catalog-header {
    margin-bottom: 40px;
  }
  
  .products-grid {
    grid-template-columns: 1fr;
    gap: 24px;
  }
  
  .product-image {
    height: 240px;
  }
  
  .card-content {
    padding: 20px;
  }
}

@media (max-width: 480px) {
  .fabric-catalog {
    padding: 40px 0;
  }
  
  .catalog-container {
    padding: 0 16px;
  }
  
  .catalog-subtitle {
    font-size: 1.1rem;
  }
}
</style>